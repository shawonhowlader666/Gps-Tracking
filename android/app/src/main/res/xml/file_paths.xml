<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- External storage root -->
    <external-path
        name="external_files"
        path="." />

    <!-- App's internal storage -->
    <files-path
        name="internal_files"
        path="." />

    <!-- App's cache directory -->
    <cache-path
        name="cache_files"
        path="." />

    <!-- App's external files directory -->
    <external-files-path
        name="external_app_files"
        path="." />

    <!-- App's external cache directory -->
    <external-cache-path
        name="external_cache_files"
        path="." />

    <!-- Download folder specifically -->
    <external-path
        name="downloads"
        path="Download/" />
</paths>